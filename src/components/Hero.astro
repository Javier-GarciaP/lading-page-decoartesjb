---
import InstagramStories from "./InstagramStories.astro";

const { title: titulo } = Astro.props;
const hayTitulo = titulo ? true : false;
---

<header class={`relative w-full ${hayTitulo ? 'min-h-[40vh]' : 'min-h-screen'} bg-bg text-secondary flex flex-col overflow-hidden font-body`}>
  
  <!-- Announcement Banner -->
  {!hayTitulo && (
    <div class="w-full border-b border-white/5 bg-white/[0.01] backdrop-blur-md text-center py-3 relative z-50 group transition-colors hover:bg-white/[0.02]">
      <a href="/dia-de-la-madre" class="text-[10px] uppercase tracking-[0.3em] font-bold text-white/70 group-hover:text-primary transition-colors flex items-center justify-center gap-6">
        <span class="w-4 h-[1px] bg-primary/50"></span>
        <span>Colección Exclusiva Día de la Madre</span>
        <span class="w-4 h-[1px] bg-primary/50"></span>
      </a>
    </div>
  )}

  <!-- Matte Dark Paper Texture Background -->
  <div class="absolute inset-0 z-0 opacity-[0.15] pointer-events-none mix-blend-overlay" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>
  
  <div class="absolute inset-0 bg-gradient-to-b from-transparent to-bg/90 z-0 pointer-events-none"></div>

  <!-- Header / Navigation -->
  <nav class="relative z-50 w-full px-6 py-6 md:px-12 flex justify-between items-center border-b border-white/5">
    <!-- Left Links -->
    <div class="hidden lg:flex flex-1 gap-12 text-[11px] font-bold tracking-[0.2em] uppercase text-white/70">
      <a href="/#sobre-mi" class="hover:text-primary transition-colors">Nosotros</a>
      <a href="/#proceso" class="hover:text-primary transition-colors">Proceso</a>
    </div>
    
    <!-- Logo Center -->
    <a href="/" class="flex-shrink-0 z-50 group mx-auto">
      <span class="font-heading font-black text-2xl md:text-3xl tracking-widest text-white uppercase">
        SJB<span class="text-primary font-light">Decoarte</span>
      </span>
    </a>
    
    <!-- Right Links & CTA -->
    <div class="hidden lg:flex flex-1 justify-end items-center gap-12 text-[11px] font-bold tracking-[0.2em] uppercase text-white/70">
      <a href="/gallery" class="hover:text-primary transition-colors">Portafolio</a>
      <a href="/#opiniones" class="hover:text-primary transition-colors">Testimonios</a>
      <a href="/#contact" class="text-white hover:text-primary transition-colors pb-1 border-b border-primary">Consulta</a>
    </div>

    <!-- Mobile Menu Button -->
    <button id="mobile-menu-btn" class="lg:hidden text-white p-2 z-50 ml-auto">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
    </button>
  </nav>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-menu" class="fixed inset-0 bg-bg/95 backdrop-blur-3xl z-40 hidden flex-col items-center justify-center gap-8 opacity-0 transition-all duration-300">
    <a href="/#sobre-mi" class="text-2xl text-white font-light hover:text-primary transition-colors">Nosotros</a>
    <a href="/#proceso" class="text-2xl text-white font-light hover:text-primary transition-colors">Proceso</a>
    <a href="/gallery" class="text-2xl text-white font-light hover:text-primary transition-colors">Portafolio</a>
    <a href="/#contact" class="text-2xl text-white font-light hover:text-primary transition-colors">Consulta</a>
  </div>

  <!-- Main Content -->
  <div class="relative z-10 flex-grow max-w-[1600px] mx-auto w-full px-6 md:px-12 py-12 flex flex-col justify-center">
    {hayTitulo ? (
      <div class="text-center">
        <h1 class="font-heading text-5xl md:text-7xl font-bold text-white mb-6 animate-fade-in-up">
          {titulo}
        </h1>
      </div>
    ) : (
      <!-- Grid System for the Layout -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center h-full">
        
        <!-- Left Column (Cols 1-3) -->
        <div class="lg:col-span-3 h-full flex flex-col justify-between py-12 order-2 lg:order-1 relative z-20">
          <div class="mb-16 lg:mb-0">
            <div class="mb-12">
              <InstagramStories />
            </div>
            <h2 class="font-heading text-4xl md:text-5xl text-white leading-[1.15] font-normal tracking-tight" style="color: #e5e5e5;">
              Diseño de <br/>
              eventos con <br/>
              elegancia y <br/>
              sofisticación.
            </h2>
          </div>
          
          <div class="mt-auto pt-12 lg:pt-0">
            <p class="text-sm text-secondary/80 leading-relaxed mb-8 max-w-[280px] font-light">
              Nuestro equipo se especializa en bodas y eventos corporativos de alto nivel en Santiago. Nos encantaría escucharte.
            </p>
            <div class="flex flex-wrap gap-3 max-w-[320px]">
              <span class="px-3 py-1.5 rounded-full border border-white/10 text-[10px] uppercase tracking-wider text-white/60 hover:border-primary/50 hover:text-primary transition-colors cursor-default">#DiseñoDeEventos</span>
              <span class="px-3 py-1.5 rounded-full border border-white/10 text-[10px] uppercase tracking-wider text-white/60 hover:border-primary/50 hover:text-primary transition-colors cursor-default">#BodasDeLujo</span>
              <span class="px-3 py-1.5 rounded-full border border-white/10 text-[10px] uppercase tracking-wider text-white/60 hover:border-primary/50 hover:text-primary transition-colors cursor-default">#CorporativosSantiago</span>
              <span class="px-3 py-1.5 rounded-full border border-white/10 text-[10px] uppercase tracking-wider text-white/60 hover:border-primary/50 hover:text-primary transition-colors cursor-default">#DecoraciónProfesional</span>
            </div>
          </div>
        </div>

        <!-- Center Composition (Cols 4-9) -->
        <div class="lg:col-span-6 relative flex justify-center items-center h-full order-1 lg:order-2 min-h-[55vh] lg:min-h-0 py-10 lg:py-0">
          
          <!-- Central Graphic Container -->
          <div class="relative w-full max-w-[450px] flex items-center justify-center">
            
            <!-- Main Statue Image (includes graphics) -->
            <div class="relative w-full z-10 flex items-center justify-center">
              <img src="/imagen_estatua.png" alt="Decoartesjb" class="w-[150%] max-w-none md:scale-110 object-contain drop-shadow-2xl" />
            </div>
            
            <!-- Show Reel Circle (Right) -->
            <div class="absolute top-[20%] -right-8 md:-right-20 z-40 hidden md:flex items-center justify-center w-32 h-32 md:w-36 md:h-36">
              <svg class="absolute w-full h-full animate-[spin_15s_linear_infinite]" viewBox="0 0 100 100">
                <path id="textPathReel" d="M 50, 50 m -34, 0 a 34,34 0 1,1 68,0 a 34,34 0 1,1 -68,0" fill="none" />
                <text class="text-[9.5px] tracking-[0.2em] uppercase fill-white/80" font-weight="500">
                  <textPath href="#textPathReel" startOffset="0%">
                    DECORACIÓN PROFESIONAL • DISEÑO DE EVENTOS •
                  </textPath>
                </text>
              </svg>
              <div class="w-10 h-10 bg-white/5 backdrop-blur-md rounded-full flex items-center justify-center border border-white/10 text-white hover:bg-primary hover:border-primary hover:text-bg transition-all cursor-pointer">
                <svg class="w-3 h-3 ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
              </div>
            </div>

            <!-- Central Typography -->
            <div class="absolute inset-0 z-30 flex flex-col justify-center items-center pointer-events-none w-full translate-y-32 md:translate-y-48">
              <h1 class="font-heading text-5xl md:text-6xl lg:text-7xl text-white leading-[0.9] tracking-tight w-full max-w-4xl text-center mix-blend-normal px-4">
                <span class="block text-white" style="text-shadow: 0 10px 40px rgba(0,0,0,0.8);">Creamos Momentos</span>
                <span class="block text-white font-light mt-2 italic" style="text-shadow: 0 10px 40px rgba(0,0,0,0.8);">Inolvidables</span>
              </h1>
            </div>

          </div>
        </div>

        <!-- Right Column (Cols 10-12) -->
        <div class="lg:col-span-3 h-full flex flex-col justify-between py-12 order-3">
          <div class="mb-16 lg:mb-0">
            <h3 class="text-[11px] font-bold tracking-[0.2em] uppercase text-primary mb-8">Nuestra Experiencia</h3>
            <ul class="space-y-0 text-sm border-t border-white/10 w-full">
              <li class="border-b border-white/10 py-5 text-white/80 font-light tracking-wide flex items-center justify-between">Atención al detalle máxima</li>
              <li class="border-b border-white/10 py-5 text-white/80 font-light tracking-wide flex items-center justify-between">Ejecución impecable</li>
              <li class="border-b border-white/10 py-5 text-white/80 font-light tracking-wide flex items-center justify-between">Soporte exclusivo</li>
            </ul>
          </div>
          
          <div class="mt-auto pt-10 lg:pt-0 flex flex-col items-start lg:items-end text-left lg:text-right">
            <p class="text-sm text-secondary/80 mb-2 font-light max-w-[200px]">Más de 15 años transformando espacios.</p>
            <div class="flex items-baseline gap-2 text-white">
              <span class="text-7xl md:text-8xl font-heading font-light leading-none tracking-tighter">15</span>
              <span class="text-sm font-bold tracking-widest uppercase text-primary">/YRS</span>
            </div>
          </div>
        </div>
        
      </div>
    )}
  </div>
</header>

<script>
  // Mobile menu toggle logic
  const toggleMenuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuLinks = mobileMenu?.querySelectorAll("a");

  function toggleMenu() {
    if (!mobileMenu) return;
    const body = document.body;

    if (mobileMenu.classList.contains("hidden")) {
      mobileMenu.classList.remove("hidden");
      mobileMenu.classList.add("flex");
      setTimeout(() => mobileMenu.classList.remove("opacity-0"), 10);
      body.style.overflow = "hidden";
    } else {
      mobileMenu.classList.add("opacity-0");
      setTimeout(() => {
        mobileMenu.classList.add("hidden");
        mobileMenu.classList.remove("flex");
      }, 300);
      body.style.overflow = "";
    }
  }

  toggleMenuBtn?.addEventListener("click", toggleMenu);
  menuLinks?.forEach(link => {
    link.addEventListener("click", toggleMenu);
  });
</script>
