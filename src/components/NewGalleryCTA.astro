---
const clipPaths = [
    "polygon(1% 4%, 12% 1%, 25% 3%, 40% 0%, 65% 2%, 85% 0%, 98% 5%, 96% 25%, 100% 50%, 97% 80%, 99% 98%, 85% 95%, 60% 99%, 35% 96%, 10% 98%, 0% 95%, 2% 75%, 0% 45%, 3% 20%)",
    "polygon(0% 2%, 15% 4%, 30% 0%, 55% 3%, 75% 1%, 100% 4%, 97% 20%, 99% 45%, 96% 70%, 100% 96%, 80% 99%, 55% 95%, 30% 98%, 5% 96%, 0% 100%, 3% 75%, 1% 40%, 4% 15%)",
    "polygon(3% 0%, 20% 3%, 45% 1%, 70% 4%, 95% 0%, 100% 25%, 98% 55%, 100% 85%, 95% 100%, 75% 96%, 50% 99%, 25% 95%, 0% 98%, 2% 70%, 0% 35%, 4% 10%)",
    "polygon(2% 1%, 22% 4%, 44% 0%, 66% 3%, 88% 1%, 99% 5%, 95% 30%, 100% 60%, 96% 88%, 98% 99%, 77% 95%, 55% 100%, 33% 97%, 11% 99%, 1% 95%, 4% 65%, 0% 35%)",
];

const images = [
  // Capa base (fondo total para no dejar huecos)
  { src: "/imagenes-nuevas/evento-2026-01.webp", className: "w-[75%] h-[75%] top-[-10%] left-[-10%] z-0" },
  { src: "/imagenes-nuevas/evento-2026-02.webp", className: "w-[75%] h-[75%] top-[-10%] right-[-10%] z-0" },
  { src: "/imagenes-nuevas/evento-2026-03.webp", className: "w-[75%] h-[75%] bottom-[-10%] left-[-10%] z-0" },
  { src: "/imagenes-nuevas/evento-2026-04.webp", className: "w-[75%] h-[75%] bottom-[-10%] right-[-10%] z-0" },
  { src: "/imagenes-nuevas/evento-2026-05.webp", className: "w-[60%] h-[60%] top-[20%] left-[20%] z-0" },
  
  // Capa media (recortes irregulares grandes)
  { src: "/imagenes-nuevas/evento-2026-06.webp", className: "w-[65%] h-[55%] top-[0%] left-[10%] z-10 -rotate-3" },
  { src: "/imagenes-nuevas/evento-2026-07.webp", className: "w-[55%] h-[65%] top-[10%] right-[-5%] z-10 rotate-6" },
  { src: "/imagenes-nuevas/evento-2026-08.webp", className: "w-[55%] h-[65%] top-[35%] left-[-5%] z-10 -rotate-6" },
  { src: "/imagenes-nuevas/evento-2026-09.webp", className: "w-[65%] h-[55%] bottom-[0%] right-[0%] z-10 rotate-3" },
  { src: "/imagenes-nuevas/evento-2026-10.webp", className: "w-[60%] h-[55%] bottom-[-5%] left-[20%] z-10 -rotate-2" },
  
  // Capa superior (recortes encima)
  { src: "/imagenes-nuevas/evento-2026-11.webp", className: "w-[50%] h-[55%] top-[25%] left-[35%] z-20 rotate-6" },
  { src: "/imagenes-nuevas/evento-2026-12.webp", className: "w-[45%] h-[45%] top-[40%] right-[10%] z-20 -rotate-12" },
  { src: "/imagenes-nuevas/evento-2026-13.webp", className: "w-[50%] h-[50%] bottom-[15%] left-[5%] z-20 rotate-12" },
  { src: "/imagenes-nuevas/evento-2026-14.webp", className: "w-[55%] h-[60%] top-[50%] left-[40%] z-20 -rotate-6" },
  { src: "/imagenes-nuevas/evento-2026-15.webp", className: "w-[45%] h-[50%] top-[5%] right-[25%] z-20 rotate-3" },
  { src: "/imagenes-nuevas/evento-2026-16.webp", className: "w-[50%] h-[50%] top-[30%] left-[5%] z-30 -rotate-6" },
  { src: "/imagenes-nuevas/evento-2026-17.webp", className: "w-[45%] h-[55%] bottom-[5%] right-[25%] z-30 rotate-12" },
].map((img, i) => ({ ...img, clipPath: clipPaths[i % clipPaths.length] }));
---

<section class="py-24 md:py-32 relative overflow-hidden bg-bg border-t border-white/5">
  <div class="max-w-[1600px] mx-auto px-6 md:px-12">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-0 border-t border-white/10 border-b">
      
      <!-- Content side -->
      <div class="lg:col-span-4 p-8 lg:p-20 flex flex-col justify-center border-b lg:border-b-0 lg:border-r border-white/10 relative z-40 bg-bg/95 backdrop-blur-md shadow-[20px_0_40px_rgba(0,0,0,0.8)]">
          <div class="mb-12">
              <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-primary mb-6 flex items-center gap-4">
                  <span class="w-8 h-[1px] bg-primary/50"></span>
                  Cartelera de Recortes
              </span>
              <h2 class="text-5xl lg:text-7xl font-heading font-light text-white leading-[1.1]">
                  Nuevos <br/>
                  Eventos <br/>
                  <span class="italic text-primary">2026</span>
              </h2>
          </div>
          
          <p class="text-sm font-light text-secondary/70 mb-16 max-w-sm leading-relaxed">
              Una mirada íntima a nuestras celebraciones más recientes. Momentos capturados, texturas, colores y el diseño editorial que define cada uno de nuestros eventos de esta temporada.
          </p>
          
          <div class="flex flex-col items-start gap-8">
              <a href="/gallery" class="text-[11px] uppercase tracking-[0.2em] font-bold text-white hover:text-primary border-b border-primary pb-2 transition-colors">
                  Ver Galería Completa →
              </a>
          </div>
      </div>

      <!-- Image side: Collage Cartelera de Recortes (Sin huecos, recortes rasgados) -->
      <div class="lg:col-span-8 relative min-h-[600px] lg:min-h-[800px] bg-[#0E0E0E] overflow-hidden group border-l border-white/5">
        
        <!-- Textura de fondo (por si acaso asoma algo en el resize, aunque está lleno) -->
        <div class="absolute inset-0 z-0 opacity-30 pointer-events-none mix-blend-overlay"
             style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E');">
        </div>
        
        <!-- Contenedor del collage -->
        <div class="absolute inset-[-10%] w-[120%] h-[120%] p-0">
            {images.map((img, i) => (
                <div 
                    class={`absolute transition-transform duration-700 hover:scale-105 hover:z-[60] cursor-pointer ${img.className} bg-[#f9f9f9] flex items-center justify-center`}
                    style={`animation: float ${12 + i}s ease-in-out infinite alternate; filter: drop-shadow(0 25px 35px rgba(0,0,0,0.95)); clip-path: ${img.clipPath}; -webkit-clip-path: ${img.clipPath};`}
                >
                    <img 
                        src={img.src} 
                        alt={`Diseño de Eventos Santiago - Collage de recortes 2026 - Foto ${i+1}`} 
                        class="w-full h-full object-cover filter brightness-95 contrast-[1.15]"
                        style={`clip-path: ${img.clipPath}; -webkit-clip-path: ${img.clipPath}; transform: scale(0.92);`}
                        loading="lazy"
                    />
                </div>
            ))}
            
            <!-- Elementos decorativos estilo scrapbooking (cintas y etiquetas) -->
            <div class="absolute top-[20%] left-[20%] w-32 h-10 bg-[#e8e8e8]/90 -rotate-12 z-[50] backdrop-blur-sm mix-blend-screen shadow-[0_10px_20px_rgba(0,0,0,0.5)]" style="clip-path: polygon(5% 0, 95% 2%, 100% 100%, 0% 98%);"></div>
            <div class="absolute top-[42%] left-[45%] w-24 h-8 bg-[#e8e8e8]/80 rotate-45 z-[50] backdrop-blur-sm mix-blend-screen shadow-[0_10px_20px_rgba(0,0,0,0.5)]" style="clip-path: polygon(2% 3%, 98% 0, 96% 100%, 3% 97%);"></div>
            <div class="absolute bottom-[25%] right-[25%] w-40 h-12 bg-[#e8e8e8]/90 -rotate-6 z-[50] backdrop-blur-sm mix-blend-screen shadow-[0_10px_20px_rgba(0,0,0,0.5)]" style="clip-path: polygon(0 0, 100% 5%, 98% 100%, 2% 95%);"></div>
            
            <!-- Etiqueta decorativa sobre los recortes -->
            <div class="absolute top-[60%] right-[15%] z-[55] -rotate-12 bg-primary text-bg font-heading text-xl md:text-3xl px-8 py-3 shadow-2xl" style="clip-path: polygon(2% 5%, 98% 0, 100% 95%, 0% 100%);">
                2026 Collection
            </div>
        </div>
        
        <!-- Gradiente para desvanecer bordes en mobile y unificar con el lado izquierdo -->
        <div class="absolute inset-0 bg-gradient-to-r from-bg/80 via-transparent to-transparent z-[50] pointer-events-none w-[15%]"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-bg via-transparent to-transparent z-[50] lg:hidden pointer-events-none"></div>
      </div>

    </div>
  </div>
</section>

<style>
  @keyframes float {
      0% { transform: translate(0px, 0px) rotate(var(--tw-rotate)); }
      50% { transform: translate(15px, -15px) rotate(calc(var(--tw-rotate) + 2deg)); }
      100% { transform: translate(-10px, 20px) rotate(calc(var(--tw-rotate) - 2deg)); }
  }
</style>
