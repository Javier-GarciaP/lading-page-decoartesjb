---

<section class="py-24 md:py-32 relative overflow-hidden bg-bg border-t border-white/5">
  <div class="max-w-[1600px] mx-auto px-6 md:px-12">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-0 border-t border-white/10 border-b">
      
      <!-- Content side -->
      <div class="lg:col-span-5 p-8 lg:p-24 flex flex-col justify-center border-b lg:border-b-0 lg:border-r border-white/10">
          <div class="mb-12">
              <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-primary mb-6 block flex items-center gap-4">
                  <span class="w-8 h-[1px] bg-primary/50"></span>
                  Recién Agregado
              </span>
              <h2 class="text-5xl lg:text-7xl font-heading font-light text-white leading-[1.1]">
                  Nueva <br/>
                  Colección <br/>
                  <span class="italic text-primary">2026</span>
              </h2>
          </div>
          
          <p class="text-sm font-light text-secondary/70 mb-16 max-w-sm leading-relaxed">
              Déjate cautivar por nuestra nueva selección premium. Historias de amor y celebraciones únicas transformadas en espacios verdaderamente mágicos.
          </p>
          
          <div class="flex flex-col items-start gap-8">
              <a href="/galeria/matrimonios" class="text-[11px] uppercase tracking-[0.2em] font-bold text-white hover:text-primary border-b border-primary pb-2 transition-colors">
                  Ver Galería Completa →
              </a>
              <a href="/galeria/matrimonio-8" class="text-[10px] uppercase tracking-[0.2em] font-bold text-secondary/50 hover:text-white transition-colors">
                  Explorar Novedades
              </a>
          </div>
      </div>

      <!-- Image side -->
      <div class="lg:col-span-7 relative overflow-hidden p-6 md:p-12 lg:p-24 flex items-center justify-center group min-h-[500px]">
        <div class="w-full relative overflow-hidden border border-white/10 p-2 max-w-[600px] aspect-square lg:aspect-auto lg:h-[80%]">
          <div class="w-full h-full relative overflow-hidden bg-white/5">
            <img 
              src="/matrimonios/matrimonio-8/imagen-1.jpg" 
              alt="Nueva Colección" 
              class="w-full h-full object-cover filter grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700 ease-out"
            />
            <div class="absolute bottom-0 right-0 bg-bg text-[10px] uppercase tracking-widest text-white/80 px-6 py-3 border-t border-l border-white/10 font-bold">
              Vol. 1
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
