---
import Section from "./Section.astro";

const opinions = [
  {
    fecha: "Diciembre 2024",
    nombre: "Berlkis Rosales",
    texto: "Jonathan es un decorador bastante profesional. Es intachable todo lo que puede realizar en un evento, ya sea un matrimonio, empresarial o muy privado. Siempre se ha destacado con sus detalles.",
    rating: 5,
    rol: "Cliente Bodas",
  },
  {
    fecha: "Enero 2025",
    nombre: "María Ruiz",
    texto: "Jonathan no tengo más palabras para felicitarte y elogiarte. Tus decoraciones son increíbles, mágicas y soñadas. Cada arreglo, cada detalle llena de armonía los espacios. Eres un artista.",
    rating: 5,
    rol: "Cliente Eventos",
  },
  {
    fecha: "Febrero 2025",
    nombre: "Margarita Ruiz",
    texto: "Jonathan, gracias por tu gran profesionalismo y excelente gusto en la decoración. Tus montajes son perfectos, bien trabajados y con resultados maravillosos. Cada puesta en escena es una sorpresa.",
    rating: 5,
    rol: "Cliente Corporativo",
  },
];

// Generar Schema.org Review JSON-LD
const reviewSchema = {
  "@context": "https://schema.org",
  "@type": "AggregateRating",
  "itemReviewed": {
    "@type": "LocalBusiness",
    "name": "SJB Decoarte",
    "image": "https://www.sjbdecoarte.cl/decoracion-catalogo.webp",
    "telephone": "+56937708933",
    "priceRange": "$$",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Santiago",
      "addressCountry": "CL"
    }
  },
  "ratingValue": "5",
  "reviewCount": "48",
  "bestRating": "5",
  "worstRating": "1"
};
---

<Section id="opiniones">
  <!-- Schema Review -->
  <script type="application/ld+json" set:html={JSON.stringify(reviewSchema)} />
  <div class="relative py-24 md:py-32 border-t border-white/5">
    <div class="max-w-[1600px] mx-auto px-6 md:px-12">
      
      <!-- Header -->
      <div class="mb-24 flex flex-col md:flex-row md:justify-between md:items-end gap-10">
        <div>
          <h3 class="text-[11px] font-bold tracking-[0.2em] uppercase text-primary mb-8 flex items-center gap-4">
            <span class="w-12 h-[1px] bg-primary/50"></span>
            Testimonios
          </h3>
          <h2 class="text-5xl lg:text-6xl font-heading font-light text-white leading-tight">
            Lo Que Dicen <br/>
            <span class="italic text-primary">Nuestros Clientes</span>
          </h2>
        </div>
        <p class="text-sm font-light text-secondary/70 max-w-sm">
          La satisfacción de nuestros clientes es nuestra mayor recompensa. Lee lo que tienen que decir sobre su experiencia.
        </p>
      </div>

      <!-- Testimonials Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-0 border-t border-white/10">
        {opinions.map((opinion, index) => (
          <div class="p-10 lg:p-16 border-b md:border-b-0 md:border-r border-white/10 last:border-r-0 flex flex-col group hover:bg-white/[0.02] transition-colors duration-500">
            
            <div class="flex gap-1 mb-10">
              {[...Array(opinion.rating)].map(() => (
                <span class="text-primary text-xs">★</span>
              ))}
            </div>

            <p class="text-sm text-secondary/80 leading-relaxed mb-16 flex-grow font-light italic">
              "{opinion.texto}"
            </p>

            <div class="border-t border-white/10 pt-8">
              <h4 class="text-white font-heading text-2xl mb-2">
                {opinion.nombre}
              </h4>
              <p class="text-[10px] text-primary uppercase tracking-[0.2em] font-bold">
                {opinion.rol}
              </p>
              <p class="text-[9px] text-white/30 uppercase tracking-widest mt-3">
                {opinion.fecha}
              </p>
            </div>

          </div>
        ))}
      </div>

    </div>
  </div>
</Section>
