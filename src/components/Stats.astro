---
import Section from "./Section.astro";

const STATS = [
    {
        number: "500",
        suffix: "+",
        label: "Eventos Exitosos",
        description: "Celebraciones memorables",
    },
    {
        number: "15",
        suffix: "+",
        label: "Años Exp.",
        description: "Perfeccionando detalles",
    },
    {
        number: "98",
        suffix: "%",
        label: "Satisfacción",
        description: "Clientes felices",
    },
    {
        number: "5",
        suffix: "★",
        label: "Calificación Promedio",
        description: "Excelencia garantizada",
    },
];
---

<Section>
    <div class="relative py-24 md:py-32 border-t border-white/5">
        <div class="max-w-[1600px] mx-auto px-6 md:px-12">
            
            <!-- Header -->
            <div class="mb-20">
                <h3 class="text-[11px] font-bold tracking-[0.2em] uppercase text-primary mb-6 flex items-center gap-4">
                    <span class="w-12 h-[1px] bg-primary/50"></span>
                    Nuestros Logros
                </h3>
                <h2 class="text-4xl md:text-5xl font-heading font-light text-white leading-tight">
                    Números que <br/>
                    <span class="italic text-primary">hablan por sí solos</span>.
                </h2>
            </div>

            <!-- Stats Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 border-t border-white/10">
                {
                    STATS.map((stat, index) => (
                        <div class="py-12 px-6 border-b lg:border-b-0 lg:border-r border-white/10 last:border-r-0 flex flex-col justify-center">
                            
                            <div class="mb-6">
                                <h3 class="text-[10px] font-bold tracking-[0.2em] uppercase text-white/60 mb-2">
                                    {stat.label}
                                </h3>
                                <p class="text-xs text-secondary/70 font-light tracking-wide">
                                    {stat.description}
                                </p>
                            </div>

                            <div class="flex items-baseline gap-2 mt-auto text-white">
                                <span class="font-heading text-6xl md:text-7xl font-light tracking-tighter">
                                    {stat.number}
                                </span>
                                {stat.suffix && (
                                    <span class="text-lg font-bold text-primary">
                                        {stat.suffix}
                                    </span>
                                )}
                            </div>

                        </div>
                    ))
                }
            </div>
            
        </div>
    </div>
</Section>
