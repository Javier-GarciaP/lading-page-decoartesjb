<footer class="relative mt-20 bg-bg border-t border-white/10 pt-24 pb-12 overflow-hidden">
    <div class="max-w-[1600px] mx-auto px-6 md:px-12 relative z-10">
        
        <div class="grid lg:grid-cols-12 gap-16 lg:gap-24 mb-24">
            <!-- Brand -->
            <div class="lg:col-span-5">
                <a href="/" class="block mb-8 group">
                    <span class="font-heading text-4xl text-white tracking-tighter font-light">
                        SJB<span class="font-bold text-primary italic pr-2">DECOARTE</span>
                    </span>
                </a>
                <p class="text-sm font-light text-secondary/70 leading-relaxed mb-10 max-w-sm">
                    Transformamos espacios en historias. Creamos experiencias visuales inolvidables con un diseño elegante y sofisticado para bodas y eventos de alto nivel en todo Chile.
                </p>
                <div class="flex items-center gap-8 border-t border-white/10 pt-8 max-w-sm">
                    <a href="https://www.instagram.com/sjbdecoarte" target="_blank" rel="noopener noreferrer" class="text-[10px] font-bold tracking-[0.2em] uppercase text-white/50 hover:text-primary transition-colors border-b border-transparent hover:border-primary pb-1">
                        Instagram
                    </a>
                    <a href="https://wa.me/56937708933" target="_blank" rel="noopener noreferrer" class="text-[10px] font-bold tracking-[0.2em] uppercase text-white/50 hover:text-primary transition-colors border-b border-transparent hover:border-primary pb-1">
                        WhatsApp
                    </a>
                </div>
            </div>

            <!-- Links -->
            <div class="lg:col-span-2">
                <h4 class="text-primary font-bold mb-8 text-[10px] uppercase tracking-[0.2em] flex items-center gap-3">
                    <span class="w-4 h-[1px] bg-primary/50"></span>
                    Explorar
                </h4>
                <ul class="space-y-6 text-[11px] font-bold tracking-widest uppercase text-white/50">
                    <li><a href="/#sobre-mi" class="hover:text-white transition-colors block">Sobre Mí</a></li>
                    <li><a href="/#servicios" class="hover:text-white transition-colors block">Servicios</a></li>
                    <li><a href="/gallery" class="hover:text-white transition-colors block">Portafolio</a></li>
                    <li><a href="/#opiniones" class="hover:text-white transition-colors block">Testimonios</a></li>
                </ul>
            </div>

            <!-- Services -->
            <div class="lg:col-span-2">
                <h4 class="text-primary font-bold mb-8 text-[10px] uppercase tracking-[0.2em] flex items-center gap-3">
                    <span class="w-4 h-[1px] bg-primary/50"></span>
                    Servicios
                </h4>
                <ul class="space-y-6 text-[11px] font-bold tracking-widest uppercase text-white/50">
                    <li><a href="/gallery" class="hover:text-white transition-colors block">Bodas</a></li>
                    <li><a href="/gallery" class="hover:text-white transition-colors block">Corporativos</a></li>
                    <li><a href="/gallery" class="hover:text-white transition-colors block">Cumpleaños</a></li>
                    <li><a href="/gallery" class="hover:text-white transition-colors block">Baby Shower</a></li>
                </ul>
            </div>

            <!-- Contact -->
            <div class="lg:col-span-3 border-l border-white/10 pl-8 lg:pl-12">
                <h4 class="text-primary font-bold mb-8 text-[10px] uppercase tracking-[0.2em] flex items-center gap-3">
                    <span class="w-4 h-[1px] bg-primary/50"></span>
                    Contacto
                </h4>
                <ul class="space-y-8 text-sm font-light text-secondary/80">
                    <li class="flex flex-col gap-1">
                        <span class="text-[9px] font-bold tracking-widest uppercase text-white/30">Ubicación</span>
                        <span class="text-white/90">Santiago, Chile<br /><span class="text-white/50">Región Metropolitana</span></span>
                    </li>
                    <li class="flex flex-col gap-1">
                        <span class="text-[9px] font-bold tracking-widest uppercase text-white/30">Email</span>
                        <a href="mailto:contacto@sjbdecoarte.cl" class="hover:text-primary transition-colors text-white/90">contacto@sjbdecoarte.cl</a>
                    </li>
                    <li class="flex flex-col gap-1">
                        <span class="text-[9px] font-bold tracking-widest uppercase text-white/30">Teléfono</span>
                        <span class="text-white/90">+56 9 3770 8933</span>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Bottom -->
        <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-6">
            <p class="text-[10px] font-bold tracking-[0.2em] uppercase text-white/30">
                &copy; {new Date().getFullYear()} SJBDECOARTE. Todos los derechos reservados.
            </p>
            <div class="flex gap-8">
                <a href="#" class="text-[9px] font-bold tracking-[0.2em] uppercase text-white/30 hover:text-primary transition-colors">Privacidad</a>
                <a href="#" class="text-[9px] font-bold tracking-[0.2em] uppercase text-white/30 hover:text-primary transition-colors">Términos</a>
            </div>
        </div>
    </div>
</footer>
