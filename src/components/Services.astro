---
import Section from "./Section.astro";

const SERVICES = [
  {
    title: "Bodas de Ensueño",
    subtitle: "El inicio de una gran historia",
    description:
      "Transformamos el día más importante de tu vida en una obra de arte. Cada detalle está pensado para reflejar su esencia como pareja, desde la ceremonia hasta la recepción.",
    image: "/matrimonios/matrimonio-2/imagen-3.jpg",
    features: [
      "Diseño Floral Exclusivo",
      "Iluminación Ambiental",
      "Coordinación Total",
    ],
  },
  {
    title: "Eventos Corporativos",
    subtitle: "Impacto y Profesionalismo",
    description:
      "Elevamos la imagen de tu marca con eventos que comunican excelencia. Diseñamos espacios que fomentan el networking y la celebración, manteniendo un equilibrio corporativo perfecto.",
    image: "/evento-empresarial/empresarial-3/imagen-13.jpg",
    features: [
      "Lanzamientos de Marca",
      "Cenas de Gala",
      "Escenografía Branding",
    ],
  },
  {
    title: "Celebraciones Sociales",
    subtitle: "Momentos para compartir",
    description:
      "Cumpleaños, aniversarios o baby showers; cada celebración merece ser única. Creamos entornos vibrantes y acogedores que invitan a la alegría y el disfrute total.",
    image: "/celebracion-social.jpg",
    features: ["Ambientación Temática", "Mesas de Dulces", "Photocalls"],
  },
];
---

<Section id="servicios">
  <div class="relative py-24 md:py-32 border-t border-white/5">
    <div class="max-w-[1600px] mx-auto px-6 md:px-12">
      <!-- Section Header -->
      <div class="mb-24 flex flex-col items-center text-center">
        <h3
          class="text-[11px] font-bold tracking-[0.2em] uppercase text-primary mb-8 flex items-center justify-center gap-4"
        >
          <span class="w-12 h-[1px] bg-primary/50"></span>
          Nuestra Excelencia
          <span class="w-12 h-[1px] bg-primary/50"></span>
        </h3>
        <h2
          class="text-5xl md:text-6xl lg:text-7xl font-heading font-light text-white leading-none"
        >
          Creamos <span class="italic text-primary">Magia</span>
        </h2>
      </div>

      <!-- Editorial Layout -->
      <div class="space-y-0">
        {
          SERVICES.map((service, index) => (
            <div
              class={`group relative flex flex-col md:flex-row items-center border-t border-white/10 ${index === SERVICES.length - 1 ? "border-b" : ""}`}
            >
              {/* Image Side */}
              <div
                class={`w-full md:w-1/2 relative border-b md:border-b-0 border-white/10 p-6 md:p-12 lg:p-24 ${index % 2 === 1 ? "md:order-last md:border-l" : "md:border-r"}`}
              >
                <div class="relative w-full aspect-[4/5] lg:aspect-square overflow-hidden border border-white/10 p-2">
                  <div class="w-full h-full relative overflow-hidden bg-white/5">
                    <img
                      src={service.image}
                      alt={service.title}
                      class="w-full h-full object-cover filter grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700 ease-out"
                      loading="lazy"
                    />
                    <div class="absolute bottom-0 left-0 bg-bg text-[10px] uppercase tracking-widest text-white/80 px-4 py-2 border-t border-r border-white/10 font-bold">
                      {index + 1 < 10 ? `0${index + 1}` : index + 1}
                    </div>
                  </div>
                </div>
              </div>

              {/* Text Side */}
              <div class="w-full md:w-1/2 p-6 md:p-12 lg:p-24 flex flex-col justify-center">
                <div class="mb-12">
                  <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-primary mb-6 block">
                    {service.subtitle}
                  </span>
                  <h3 class="text-4xl md:text-5xl lg:text-6xl font-heading font-light text-white leading-tight">
                    {service.title}
                  </h3>
                </div>

                <p class="text-sm text-secondary/70 font-light leading-relaxed mb-12 max-w-md">
                  {service.description}
                </p>

                <div class="border-t border-white/10 pt-8 mb-16">
                  <ul class="flex flex-col gap-5">
                    {service.features.map((feature) => (
                      <li class="flex items-center gap-4 text-[10px] font-bold tracking-[0.2em] uppercase text-white/80">
                        <span class="w-2 h-[1px] bg-primary" />
                        {feature}
                      </li>
                    ))}
                  </ul>
                </div>

                <div>
                  <a
                    href="#contact"
                    class="text-[11px] uppercase tracking-[0.2em] font-bold text-white hover:text-primary border-b border-primary pb-2 transition-colors inline-flex items-center gap-2"
                  >
                    Diseñar mi evento →
                  </a>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</Section>
