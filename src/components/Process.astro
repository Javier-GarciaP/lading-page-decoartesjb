---
import Section from "./Section.astro";

const PROCESS_STEPS = [
  {
    step: "01.",
    title: "Conexión",
    description: "Nos reunimos para escuchar tus sueños. Entendemos tu visión, gustos y la esencia que deseas transmitir en tu evento."
  },
  {
    step: "02.",
    title: "Diseño",
    description: "Creamos una propuesta visual única. Bocetos, paletas de colores y selección de materiales para dar vida a la idea."
  },
  {
    step: "03.",
    title: "Magia",
    description: "La ejecución impecable. Nuestro equipo transforma el espacio cuidando cada flor, cada luz y cada detalle."
  },
  {
    step: "04.",
    title: "Celebración",
    description: "El momento de disfrutar. Todo está listo para que tú y tus invitados vivan una experiencia inolvidable."
  }
];
---

<Section id="proceso">
  <div class="relative py-24 md:py-32 border-t border-white/5">
    <div class="max-w-[1600px] mx-auto px-6 md:px-12">
      
      <!-- Header -->
      <div class="mb-24 flex flex-col md:flex-row md:justify-between md:items-end gap-10">
        <div>
          <h3 class="text-[11px] font-bold tracking-[0.2em] uppercase text-primary mb-8 flex items-center gap-4">
            <span class="w-12 h-[1px] bg-primary/50"></span>
            Cómo trabajamos
          </h3>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-heading font-light text-white leading-tight">
            El Proceso <br/>
            <span class="italic text-primary">Creativo</span>
          </h2>
        </div>
        <p class="text-sm font-light text-secondary/80 max-w-sm">
          De la imaginación a la realidad. Un camino cuidado al detalle para garantizar la excelencia en cada evento que diseñamos.
        </p>
      </div>

      <!-- Timeline Process -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 border-t border-white/10">
        {PROCESS_STEPS.map((step, index) => (
          <div class="py-16 px-6 lg:px-8 border-b lg:border-b-0 lg:border-r border-white/10 last:border-r-0 flex flex-col group hover:bg-white/[0.02] transition-colors duration-500">
            
            <span class="text-5xl font-heading text-white/10 mb-12 block font-light group-hover:text-primary transition-colors duration-500">
              {step.step}
            </span>
            
            <h3 class="text-[11px] font-bold tracking-[0.2em] uppercase text-white/90 mb-6">
              {step.title}
            </h3>
            
            <p class="text-sm font-light text-secondary/70 leading-relaxed">
              {step.description}
            </p>
            
          </div>
        ))}
      </div>

      <!-- CTA -->
      <div class="mt-20 flex justify-end pr-6">
         <a href="/#contact" class="text-[11px] uppercase tracking-[0.2em] font-bold text-white hover:text-primary border-b border-primary pb-2 transition-colors">
            Comenzar mi proyecto →
         </a>
      </div>

    </div>
  </div>
</Section>
