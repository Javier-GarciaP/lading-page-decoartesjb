---
import Section from "./Section.astro";
---

<Section id="sobre-mi">
  <section
    class="relative py-24 md:py-32 overflow-hidden border-t border-white/5"
  >
    <div class="max-w-[1600px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
        <!-- Left Side: Image -->
        <div
          class="lg:col-span-5 relative flex justify-center order-2 lg:order-1"
        >
          <!-- Editorial Image Frame -->
          <div
            class="relative w-full max-w-[400px] aspect-[4/5] border border-white/10 p-2"
          >
            <div class="w-full h-full overflow-hidden relative">
              <img
                src="/perfil/perfil-3.webp"
                alt="Jonathan - Decoartesjb"
                class="w-full h-full object-cover filter grayscale hover:grayscale-0 transition-all duration-700"
                loading="lazy"
              />
              <!-- Editorial accent -->
              <div
                class="absolute bottom-4 left-4 bg-bg text-[9px] uppercase tracking-widest text-white/80 px-4 py-2 border border-white/10 font-bold"
              >
                Est. 2009
              </div>
            </div>
          </div>
        </div>

        <!-- Right Side: Content -->
        <div
          class="lg:col-span-7 order-1 lg:order-2 flex flex-col justify-center"
        >
          <div class="mb-12">
            <h3
              class="text-[11px] font-bold tracking-[0.2em] uppercase text-primary mb-8 flex items-center gap-4"
            >
              <span class="w-12 h-[1px] bg-primary/50"></span>
              Sobre Nosotros
            </h3>
            <h2
              class="font-heading text-5xl md:text-6xl font-light text-white leading-tight mb-8"
            >
              Transformamos <br />
              espacios en <br />
              <span class="italic text-primary">escenarios memorables</span>.
            </h2>

            <div
              class="space-y-6 text-sm text-secondary/80 font-light max-w-lg leading-relaxed"
            >
              <p>
                Soy <span class="text-white">Jonathan</span>, emprendedor con
                más de 15 años creando atmósferas únicas para bodas, matrimonios y eventos
                corporativos de alto nivel en <span class="text-white">Santiago de Chile</span>.
              </p>
              <p>
                Atendemos toda la <span class="text-white">Región Metropolitana</span>: Las Condes, Providencia, Vitacura, Ñuñoa, Maipú, La Florida, San Bernardo, Puente Alto, Lo Barnechea y comunas aledañas.
              </p>
              <p>
                Mi compromiso es convertir tu visión en realidad, diseñando cada
                detalle con pasión y precisión para superar expectativas y crear
                momentos que perduran en la memoria.
              </p>
            </div>
          </div>

          <!-- Features list (editorial style) -->
          <div
            class="grid grid-cols-2 gap-x-8 gap-y-0 border-t border-white/10 pt-8 mt-4 max-w-lg"
          >
            <div
              class="border-b border-white/5 py-4 text-[10px] font-bold tracking-widest uppercase text-white/70"
            >
              Diseño Único
            </div>
            <div
              class="border-b border-white/5 py-4 text-[10px] font-bold tracking-widest uppercase text-white/70"
            >
              Atención al Detalle
            </div>
            <div
              class="border-b border-white/5 py-4 text-[10px] font-bold tracking-widest uppercase text-white/70"
            >
              Calidad Premium
            </div>
            <div
              class="border-b border-white/5 py-4 text-[10px] font-bold tracking-widest uppercase text-white/70"
            >
              15+ Años de Exp.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Section>
