---

<Layout
  title="Galería de Matrimonios y Bodas en Santiago de Chile"
  description="Portafolio de decoración de matrimonios y bodas en Santiago de Chile. 26+ ceremonias únicas decoradas por SJB Decoarte en la Región Metropolitana. Cada boda diseñada con elegancia y atención al detalle."
>
  <section
    class="px-6 md:px-10 py-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8"
  >
    {
      galleryEvents.map((event) => (
        <a
          href={event.route}
          class="group block relative rounded-xl overflow-hidden shadow-lg"
        >
          <img
            src={event.image}
            alt={`${event.title} - Decoración de matrimonios en Santiago - SJB Decoarte`}
            class="w-full h-64 object-cover transform transition duration-300 group-hover:scale-110"
            loading="lazy"
          />
          {event.isNew && (
            <div class="absolute top-4 left-4 z-20 pointer-events-none">
              <span class="bg-primary text-secondary text-[10px] font-bold px-3 py-1.5 rounded-full uppercase tracking-widest shadow-xl flex items-center gap-1.5 backdrop-blur-md border border-white/20">
                <span class="relative flex h-2 w-2">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-secondary opacity-75" />
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-secondary" />
                </span>
                Nuevo
              </span>
            </div>
          )}
          <div class="absolute inset-0 bg-black/50 flex flex-col justify-end p-4 opacity-0 group-hover:opacity-100 transition">
            <h3 class="text-white text-xl font-bold">{event.title}</h3>
            <p class="text-white text-sm mt-1">{event.description}</p>
          </div>
        </a>
      ))
    }
  </section>
</Layout>
