---
import Layout from "../layouts/Layout.astro";
import Section from "../components/Section.astro";
import DownloadCatalog from "../components/pdf/CatalogPDF";
import catalogo from "../data/catalogo.json";

interface CatalogItem {
    id: number;
    group: string;
    title: string;
    description: string;
    price: number;
    type: string;
    image: string;
}

interface GroupedItem {
    title: string;
    description: string;
    price: number;
    items: CatalogItem[];
}

// Agrupación por la propiedad 'group'
const groupedMap = (catalogo as CatalogItem[]).reduce<Record<string, GroupedItem>>((acc, item) => {
    const key = item.group || "Otros";
    if (!acc[key]) {
        acc[key] = {
            title: key,
            description: item.description,
            price: item.price,
            items: [],
        };
    }
    acc[key].items.push(item);
    return acc;
}, {});
const groupedArray: GroupedItem[] = Object.values(groupedMap);
---

<Layout title="Especial Día de la Madre" showHero={false}>

    <!-- ═══════════════════════════════════════════════
         HERO — Igual al diseño de la página principal
    ════════════════════════════════════════════════ -->
    <header class="relative w-full min-h-screen bg-bg text-secondary flex flex-col overflow-hidden font-body">

        <!-- Textura de fondo oscura -->
        <div class="absolute inset-0 z-0 opacity-[0.15] pointer-events-none mix-blend-overlay"
             style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E');">
        </div>
        <div class="absolute inset-0 bg-gradient-to-b from-transparent to-bg/90 z-0 pointer-events-none"></div>

        <!-- ── Nav (idéntica al Hero) ── -->
        <nav class="relative z-50 w-full px-6 py-6 md:px-12 flex justify-between items-center border-b border-white/5">
            <div class="hidden lg:flex flex-1 gap-12 text-[11px] font-bold tracking-[0.2em] uppercase text-white/70">
                <a href="/#sobre-mi" class="hover:text-primary transition-colors">Nosotros</a>
                <a href="/#proceso"   class="hover:text-primary transition-colors">Proceso</a>
            </div>

            <a href="/" class="flex-shrink-0 z-50 group mx-auto">
                <span class="font-heading font-black text-2xl md:text-3xl tracking-widest text-white uppercase">
                    SJB<span class="text-primary font-light">Decoarte</span>
                </span>
            </a>

            <div class="hidden lg:flex flex-1 justify-end items-center gap-12 text-[11px] font-bold tracking-[0.2em] uppercase text-white/70">
                <a href="/gallery"    class="hover:text-primary transition-colors">Portafolio</a>
                <a href="/#opiniones" class="hover:text-primary transition-colors">Testimonios</a>
                <a href="/#contact"   class="text-white hover:text-primary pb-1 border-b border-primary transition-colors">Consulta</a>
            </div>

            <!-- Mobile -->
            <button id="mobile-menu-btn" class="lg:hidden text-white p-2 z-50 ml-auto">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                    <line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/>
                </svg>
            </button>
        </nav>

        <!-- Mobile overlay -->
        <div id="mobile-menu" class="fixed inset-0 bg-bg/95 backdrop-blur-3xl z-40 hidden flex-col items-center justify-center gap-8 opacity-0 transition-all duration-300">
            <a href="/#sobre-mi" class="text-2xl text-white font-light hover:text-primary transition-colors">Nosotros</a>
            <a href="/#proceso"  class="text-2xl text-white font-light hover:text-primary transition-colors">Proceso</a>
            <a href="/gallery"   class="text-2xl text-white font-light hover:text-primary transition-colors">Portafolio</a>
            <a href="/#contact"  class="text-2xl text-white font-light hover:text-primary transition-colors">Consulta</a>
        </div>

        <!-- ── Grilla principal (misma estructura 3-6-3 del Hero) ── -->
        <div class="relative z-10 flex-grow max-w-[1600px] mx-auto w-full px-6 md:px-12 py-12 flex flex-col justify-center">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center h-full">

                <!-- Columna izquierda -->
                <div class="lg:col-span-3 h-full flex flex-col justify-between py-12 order-2 lg:order-1">
                    <div class="mb-16 lg:mb-0">
                        <span class="text-[10px] font-bold tracking-[0.3em] uppercase text-primary mb-6 block">
                            Colección Especial · 2026
                        </span>
                        <h2 class="font-heading text-4xl md:text-5xl text-white leading-[1.15] font-normal tracking-tight">
                            Un regalo<br/>
                            hecho con<br/>
                            amor y<br/>
                            flores.
                        </h2>
                    </div>

                    <div class="mt-auto pt-12 lg:pt-0">
                        <p class="text-sm text-secondary/70 leading-relaxed mb-8 max-w-[280px] font-light">
                            Diseñamos arreglos florales únicos para honrar a mamá con la elegancia que merece.
                        </p>

                        <!-- Info entrega y pago — minimalista -->
                        <ul class="space-y-0 text-xs border-t border-white/10 max-w-[280px]">
                            <li class="border-b border-white/10 py-4 text-white/60 font-light flex items-center gap-3">
                                <span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></span>
                                Pago por transferencia
                            </li>
                            <li class="border-b border-white/10 py-4 text-white/60 font-light flex items-center gap-3">
                                <span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></span>
                                Delivery Región Metropolitana
                            </li>
                            <li class="py-4 text-primary/80 font-light flex items-center gap-3 text-[11px] tracking-wider">
                                <span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></span>
                                Consultar por DM
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Columna central — estatua del Día de la Madre -->
                <div class="lg:col-span-6 relative flex justify-center items-center h-full order-1 lg:order-2 min-h-[55vh] lg:min-h-0 py-10 lg:py-0">
                    <div class="relative w-full max-w-[450px] flex items-center justify-center">

                        <div class="relative w-full z-10 flex items-center justify-center">
                            <img
                                src="/estatua-madre.png"
                                alt="Día de la Madre — SJB Decoarte"
                                class="w-[140%] max-w-none object-contain drop-shadow-2xl"
                            />
                        </div>

                        <!-- Círculo giratorio (como en el Hero) -->
                        <div class="absolute top-[15%] -right-8 md:-right-20 z-40 hidden md:flex items-center justify-center w-32 h-32 md:w-36 md:h-36">
                            <svg class="absolute w-full h-full animate-[spin_18s_linear_infinite]" viewBox="0 0 100 100">
                                <path id="txtPath" d="M 50, 50 m -34, 0 a 34,34 0 1,1 68,0 a 34,34 0 1,1 -68,0" fill="none"/>
                                <text class="text-[9.5px] tracking-[0.2em] uppercase fill-white/80" font-weight="500">
                                    <textPath href="#txtPath" startOffset="0%">FLORES PREMIUM • DÍA DE LA MADRE •</textPath>
                                </text>
                            </svg>
                            <div class="w-10 h-10 bg-white/5 backdrop-blur-md rounded-full flex items-center justify-center border border-white/10">
                                <svg class="w-3 h-3 text-primary" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                                </svg>
                            </div>
                        </div>

                        <!-- Tipografía central -->
                        <div class="absolute inset-0 z-30 flex flex-col justify-center items-center pointer-events-none w-full translate-y-32 md:translate-y-52">
                            <h1 class="font-heading text-5xl md:text-6xl lg:text-7xl text-white leading-[0.9] tracking-tight text-center px-4">
                                <span class="block text-white" style="text-shadow: 0 10px 40px rgba(0,0,0,0.8);">Día de</span>
                                <span class="block text-white font-light mt-2 italic" style="text-shadow: 0 10px 40px rgba(0,0,0,0.8);">la Madre</span>
                            </h1>
                        </div>

                    </div>
                </div>

                <!-- Columna derecha -->
                <div class="lg:col-span-3 h-full flex flex-col justify-between py-12 order-3">
                    <div class="mb-16 lg:mb-0">
                        <h3 class="text-[11px] font-bold tracking-[0.2em] uppercase text-primary mb-8">Nuestros Arreglos</h3>
                        <ul class="space-y-0 text-sm border-t border-white/10 w-full">
                            <li class="border-b border-white/10 py-5 text-white/80 font-light tracking-wide">Selección Premium de Flores</li>
                            <li class="border-b border-white/10 py-5 text-white/80 font-light tracking-wide">Diseño Editorial Único</li>
                            <li class="border-b border-white/10 py-5 text-white/80 font-light tracking-wide">Papelería de Alta Gama</li>
                            <li class="border-b border-white/10 py-5 text-white/80 font-light tracking-wide">Entrega Personalizada</li>
                        </ul>
                    </div>

                    <div class="mt-auto pt-10 lg:pt-0 flex flex-col items-start lg:items-end text-left lg:text-right">
                        <p class="text-sm text-secondary/80 mb-2 font-light max-w-[200px]">Celebramos cada detalle.</p>
                        <div class="flex items-baseline gap-2 text-white">
                            <span class="text-7xl md:text-8xl font-heading font-light leading-none tracking-tighter">10</span>
                            <span class="text-sm font-bold tracking-widest uppercase text-primary">/MAY</span>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </header>

    <!-- ═══════════════════════════════════════════════
         CATÁLOGO
    ════════════════════════════════════════════════ -->
    <Section id="catalogo">
        <div class="relative py-32 border-t border-white/5">

            <!-- Encabezado sección -->
            <div class="max-w-[1600px] mx-auto px-6 md:px-12 mb-24 text-center">
                <span class="text-[11px] font-bold tracking-[0.4em] uppercase text-primary mb-6 block">Catálogo Exclusivo</span>
                <h2 class="text-5xl md:text-7xl font-heading font-light text-white leading-none">
                    Arreglos que <span class="italic text-primary font-normal">Cuentan Historias</span>
                </h2>
                <div class="mt-12 flex justify-center">
                    <DownloadCatalog client:only="react" />
                </div>
            </div>

            <!-- Grupos de productos -->
            <div class="max-w-[1400px] mx-auto px-6 md:px-12">
                {groupedArray.map((group) => (
                    <div class="mb-28 last:mb-0 reveal">

                        <!-- Cabecera del grupo -->
                        <div class="flex flex-col md:flex-row justify-between items-baseline mb-12 border-l-2 border-primary pl-8">
                            <div class="max-w-2xl">
                                <h3 class="font-heading text-3xl md:text-5xl text-white mb-4 tracking-tight uppercase">{group.title}</h3>
                                <p class="text-secondary/60 font-light italic leading-relaxed">{group.description}</p>
                            </div>
                            <div class="mt-6 md:mt-0 text-right flex-shrink-0">
                                <span class="text-xs font-bold tracking-[0.3em] uppercase text-primary/50 block mb-2">Desde</span>
                                <span class="text-3xl font-heading text-white">${group.price.toLocaleString('es-CL')}</span>
                            </div>
                        </div>

                        <!-- Grid de flores -->
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
                            {group.items.map((item) => (
                                <div
                                    class="group perspective-1000 cursor-pointer"
                                    onclick={`openLightbox('/ramos-dia-madre/${item.image}')`}
                                >
                                    <div class="relative transform-style-3d transition-all duration-700 group-hover:rotate-y-6 group-hover:-rotate-x-3">
                                        <div class="border border-white/8 p-6 bg-white/[0.015] backdrop-blur-sm group-hover:border-primary/30 transition-all duration-500">
                                            <div class="relative overflow-visible h-[300px] flex items-center justify-center">
                                                <img
                                                    src={`/ramos-dia-madre/${item.image}`}
                                                    alt={item.title}
                                                    class="w-full h-full object-contain transform transition-all duration-700 group-hover:scale-105 group-hover:-translate-y-4 drop-shadow-[0_10px_30px_rgba(0,0,0,0.5)] group-hover:drop-shadow-[0_25px_50px_rgba(212,175,55,0.25)]"
                                                    loading="lazy"
                                                />
                                            </div>
                                        </div>
                                        <div class="mt-3 flex items-center justify-between px-1">
                                            <span class="text-[10px] uppercase tracking-widest text-white/20">Ref. {String(item.id).padStart(2,'0')}</span>
                                            <div class="w-1.5 h-1.5 rounded-full bg-primary/20 group-hover:bg-primary transition-colors duration-300"></div>
                                        </div>
                                    </div>
                                </div>
                            ))}
                        </div>

                    </div>
                ))}
            </div>

        </div>
    </Section>

    <!-- ═══════════════════════════════════════════════
         CTA FINAL
    ════════════════════════════════════════════════ -->
    <Section id="reserva">
        <div class="relative py-32 border-t border-white/5 text-center overflow-hidden">
            <div class="absolute inset-0 bg-primary/5 blur-[120px] rounded-full -translate-y-1/2 pointer-events-none"></div>
            <div class="relative z-10">
                <span class="text-[10px] font-bold tracking-[0.4em] uppercase text-primary/70 block mb-8">10 de Mayo · 2026</span>
                <h2 class="text-4xl md:text-6xl font-heading font-light text-white mb-12 max-w-3xl mx-auto px-6 leading-tight">
                    Hagamos que este día sea<br/>
                    <span class="italic text-primary font-normal">absolutamente inolvidable.</span>
                </h2>
                <a href="/#contact" class="inline-flex items-center gap-6 group">
                    <span class="text-[11px] font-bold tracking-[0.4em] uppercase text-white group-hover:text-primary transition-colors">
                        Agendar Pedido Ahora
                    </span>
                    <div class="w-12 h-12 rounded-full border border-white/20 flex items-center justify-center group-hover:border-primary group-hover:translate-x-2 transition-all duration-300">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                        </svg>
                    </div>
                </a>
            </div>
        </div>
    </Section>

    <!-- Lightbox -->
    <div id="lightbox" class="fixed inset-0 z-[200] bg-bg/95 hidden flex justify-center items-center opacity-0 transition-all duration-300 backdrop-blur-md">
        <button
            class="absolute top-8 right-8 text-white/40 hover:text-primary transition-all focus:outline-none z-50 p-2 hover:rotate-90 duration-500"
            onclick="closeLightbox()"
        >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-9 w-9" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M6 18L18 6M6 6l12 12"/>
            </svg>
        </button>
        <img id="lightbox-img" src="" alt="Vista ampliada" class="max-h-[85vh] max-w-[90vw] object-contain shadow-2xl transform scale-95 transition-transform duration-500"/>
    </div>

</Layout>

<style>
    .perspective-1000    { perspective: 1000px; }
    .transform-style-3d  { transform-style: preserve-3d; }
    .rotate-y-6          { transform: rotateY(6deg); }
    .-rotate-x-3         { transform: rotateX(-3deg); }

    .reveal {
        opacity: 0;
        transform: translateY(28px);
        transition: opacity 0.9s cubic-bezier(0.2, 1, 0.3, 1), transform 0.9s cubic-bezier(0.2, 1, 0.3, 1);
    }
    .reveal.active {
        opacity: 1;
        transform: translateY(0);
    }
</style>

<script is:inline>
    /* ── Lightbox ── */
    function openLightbox(src) {
        const lb  = document.getElementById('lightbox');
        const img = document.getElementById('lightbox-img');
        img.src = src;
        lb.classList.remove('hidden');
        requestAnimationFrame(() => {
            lb.classList.remove('opacity-0');
            img.classList.replace('scale-95', 'scale-100');
        });
        document.body.style.overflow = 'hidden';
    }
    function closeLightbox() {
        const lb  = document.getElementById('lightbox');
        const img = document.getElementById('lightbox-img');
        lb.classList.add('opacity-0');
        img.classList.replace('scale-100', 'scale-95');
        setTimeout(() => { lb.classList.add('hidden'); img.src = ''; }, 300);
        document.body.style.overflow = '';
    }
    document.getElementById('lightbox')?.addEventListener('click', e => {
        if (e.target.id === 'lightbox') closeLightbox();
    });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });

    /* ── Reveal on scroll ── */
    const revealObserver = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('active'); });
    }, { threshold: 0.08 });
    document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

    /* ── Mobile menu ── */
    const btn  = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => {
        if (menu.classList.contains('hidden')) {
            menu.classList.remove('hidden');
            menu.classList.add('flex');
            setTimeout(() => menu.classList.remove('opacity-0'), 10);
            document.body.style.overflow = 'hidden';
        } else {
            menu.classList.add('opacity-0');
            setTimeout(() => { menu.classList.add('hidden'); menu.classList.remove('flex'); }, 300);
            document.body.style.overflow = '';
        }
    });
    menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
        menu.classList.add('opacity-0');
        setTimeout(() => { menu.classList.add('hidden'); menu.classList.remove('flex'); }, 300);
        document.body.style.overflow = '';
    }));
</script>
