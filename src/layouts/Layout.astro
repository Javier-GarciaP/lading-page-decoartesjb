            {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Decoración de Bodas y Matrimonios en Santiago"}},
            {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Decoración de Cumpleaños en Santiago"}},
            {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Decoración Baby Shower Santiago"}},
