        "url": "https://www.sjbdecoarte.cl",
        "logo": "https://www.sjbdecoarte.cl/favicon.png",
        "image": "https://www.sjbdecoarte.cl/decoracion-catalogo.webp",
        "telephone": "+56937708933",
        "email": "sjbdecoarte@gmail.com",
        "foundingDate": "2009",
        "priceRange": "$$",
        "currenciesAccepted": "CLP",
        "paymentAccepted": "Transferencia bancaria, Efectivo",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Santiago",
